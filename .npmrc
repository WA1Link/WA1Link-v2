# React-i18next v14 / i18next v23 are pinned to satisfy this project's
# TypeScript 4.9.5 (locked by react-scripts 5.0.1). Newer react-i18next
# requires TS 5+. legacy-peer-deps lets npm proceed without erroring on
# the optional TS peer-dep mismatch and is required for both `npm install`
# and the CI's `npm ci` to work consistently across Windows/macOS/Linux.
legacy-peer-deps=true
