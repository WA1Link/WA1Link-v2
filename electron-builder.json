{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.wa1link.app",
  "productName": "WA1Link",
  "extends": null,
  "directories": {
    "output": "dist-electron",
    "buildResources": "build"
  },
  "files": [
    "build/**/*",
    "dist/main/**/*",
    "dist/preload/**/*",
    "dist/shared/**/*"
  ],
  "extraResources": [],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "build/logoWa1Link.ico"
  },
  "nsis": {
    "artifactName": "${productName}-Setup-${version}-${os}-${arch}.${ext}",
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "installerIcon": "build/logoWa1Link.ico",
    "uninstallerIcon": "build/logoWa1Link.ico",
    "installerHeaderIcon": "build/logoWa1Link.ico"
  },
  "mac": {
    "target": [
      {
        "target": "zip",
        "arch": ["arm64"]
      }
    ],
    "icon": "build/logoWa1Link.icns",
    "category": "public.app-category.business",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "assets/entitlements.mac.plist",
    "entitlementsInherit": "assets/entitlements.mac.plist",
    "notarize": false,
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      },
      {
        "target": "deb",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icons",
    "category": "Office",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  },
  "publish": {
    "provider": "github",
    "owner": "WA1Link",
    "repo": "WA1Link-v2",
    "releaseType": "release"
  }
}
