{
  "name": "wa1link-v2",
  "version": "1.4.1",
  "description": "WhatsApp Bulk Messaging Desktop App",
  "main": "dist/main/main/index.js",
  "homepage": "./",
  "scripts": {
    "start": "concurrently \"npm run start:react\" \"npm run start:electron\"",
    "start:react": "react-scripts start",
    "start:electron": "wait-on http://localhost:3000 && electron .",
    "dev": "npm run build:electron && concurrently \"npm run start:react\" \"npm run watch:electron\" \"npm run dev:electron\"",
    "watch:electron": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on http://localhost:3000 && electronmon .",
    "build": "react-scripts build",
    "build:electron": "tsc -p tsconfig.main.json",
    "build:win": "npm run build && npm run build:electron && electron-builder --win",
    "build:mac": "npm run build && npm run build:electron && electron-builder --mac",
    "build:linux": "npm run build && npm run build:electron && electron-builder --linux",
    "build:all": "npm run build && npm run build:electron && electron-builder -mwl",
    "release": "npm run build && npm run build:electron && electron-builder --publish always",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.9",
    "better-sqlite3": "^11.5.0",
    "electron-updater": "^6.6.2",
    "moment": "^2.30.1",
    "pino": "^9.9.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electronmon": "^2.0.4",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.0",
    "react-scripts": "5.0.1",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.0",
    "typescript": "^4.9.5",
    "vitest": "^4.1.2",
    "wait-on": "^8.0.0"
  },
  "browserslist": {
    "production": [
      "last 1 electron version"
    ],
    "development": [
      "last 1 electron version"
    ]
  }
}
